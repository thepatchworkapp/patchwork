# ===================
# Convex
# ===================
CONVEX_DEPLOYMENT=dev:your-project-name

# ===================
# Local origins
# ===================
SITE_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:4321
ADMIN_APP_ORIGIN=http://localhost:4321
# Admin allowlist (comma-separated). Prefer ADMIN_EMAILS; ADMIN_EMAIL is legacy fallback.
ADMIN_EMAILS=admin@example.com
ADMIN_EMAIL=admin@example.com

# ===================
# OTP Email (Resend)
# ===================
RESEND_API_KEY=re_xxxxxxxxxxxxx
OTP_FROM_EMAIL=otp@diaper.exchange
ENABLE_TESTING_HELPERS=true

# ===================
# Better Auth
# ===================
BETTER_AUTH_SECRET=your-random-secret-32-chars-min
BETTER_AUTH_URL=http://localhost:3000

# ===================
# OAuth Providers
# ===================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===================
# RevenueCat
# ===================
REVENUECAT_WEBHOOK_AUTHORIZATION=Bearer your-shared-secret

# ===================
# App
# ===================
APP_URL=http://localhost:3000
